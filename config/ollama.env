# Shared Ollama endpoint for this deployment (LAN inference host).
# Override anytime: export OLLAMA_BASE_URL=... before running scripts.
#
# Core path: this host must reach the Ollama LAN address. Public internet
# is still not required. Change if your Ollama moves.

OLLAMA_BASE_URL="${OLLAMA_BASE_URL:-http://192.168.200.120:11434}"

# Weights/tags that already exist on the remote Ollama library
OLLAMA_ADMIN_MODEL="${OLLAMA_ADMIN_MODEL:-qwen2.5-coder:7b}"
OLLAMA_FAST_MODEL="${OLLAMA_FAST_MODEL:-llama3.2:3b}"
