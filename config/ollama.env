# Ollama endpoints for linux-admin
#
# Primary: LAN inference host (full model library) — T4 16GB class.
# Fallback: one small model on this machine when LAN is down.
#
# OLLAMA_ADMIN_MODEL is set by bootstrap via pick-admin-model.py (T4-aware).
# Override any value via environment.

# --- Primary (remote / LAN) ---
OLLAMA_BASE_URL="${OLLAMA_BASE_URL:-http://192.168.200.120:11434}"
# Leave as "auto" to re-pick on bootstrap --pick; or pin a tag explicitly.
OLLAMA_ADMIN_MODEL="${OLLAMA_ADMIN_MODEL:-auto}"
OLLAMA_FAST_MODEL="${OLLAMA_FAST_MODEL:-llama3.2:3b}"

# --- Fallback (on this host) ---
OLLAMA_LOCAL_BASE_URL="${OLLAMA_LOCAL_BASE_URL:-http://127.0.0.1:11434}"
OLLAMA_LOCAL_MODEL="${OLLAMA_LOCAL_MODEL:-llama3.2:3b}"
