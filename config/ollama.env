# Ollama endpoints for linux-admin
#
# Primary: LAN inference host (full model library).
# Fallback: local Ollama on this machine with ONE small model so admin still
# works when 192.168.200.120 is down (e.g. troubleshooting that host).
#
# Override any value via environment before running scripts.

# --- Primary (remote / LAN) ---
OLLAMA_BASE_URL="${OLLAMA_BASE_URL:-http://192.168.200.120:11434}"
OLLAMA_ADMIN_MODEL="${OLLAMA_ADMIN_MODEL:-qwen2.5-coder:7b}"
OLLAMA_FAST_MODEL="${OLLAMA_FAST_MODEL:-llama3.2:3b}"

# --- Fallback (on this host) ---
OLLAMA_LOCAL_BASE_URL="${OLLAMA_LOCAL_BASE_URL:-http://127.0.0.1:11434}"
# Keep this small — for break-glass admin when the LAN Ollama is unreachable
OLLAMA_LOCAL_MODEL="${OLLAMA_LOCAL_MODEL:-llama3.2:3b}"

# Auto-select: if primary is up → ollama-admin; else → ollama-local
# Force with: LINUX_ADMIN_MODEL=ollama-local  or  LINUX_ADMIN_MODEL=ollama-admin
