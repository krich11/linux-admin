#!/usr/bin/env bash
# Primary CLI entry: Grok-style TUI pre-wired for this repo.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

export PATH="${ROOT}/mcp/linux_admin/.venv/bin:${HOME}/.local/bin:${PATH}"
# shellcheck source=/dev/null
source "$ROOT/scripts/lib-env.sh"

# Best-effort: ensure Grok model entries exist (primary + local)
if [[ -x "$ROOT/scripts/install-user-models.sh" ]]; then
  "$ROOT/scripts/install-user-models.sh" >/dev/null 2>&1 || true
fi

# Auto-select primary vs local unless LINUX_ADMIN_MODEL is forced
MODEL="$(select_grok_model || true)"
MODEL="${MODEL:-ollama-local}"

usage() {
  cat <<EOF
linux-admin — local Linux admin agent (Grok-style CLI)

Usage:
  linux-admin                 Start interactive Grok TUI (auto model select)
  linux-admin -p "prompt"     Headless one-shot (also: --print)
  linux-admin creds ...       Credential repository CLI
  linux-admin doctor          Core path health checks
  linux-admin doctor-offline  Core-path checks (no public cloud LLM)
  linux-admin bootstrap       Install deps + register models + local fallback
  linux-admin ensure-local    Pull/start local break-glass model only
  linux-admin mcp             Run linux-admin-mcp on stdio (debug)
  linux-admin help            This help

Model selection (auto):
  1) LAN Ollama  → Grok id ollama-admin  (${OLLAMA_BASE_URL} / ${OLLAMA_ADMIN_MODEL})
  2) Local Ollama → Grok id ollama-local (${OLLAMA_LOCAL_BASE_URL} / ${OLLAMA_LOCAL_MODEL})

Force a model:
  LINUX_ADMIN_MODEL=ollama-admin linux-admin
  LINUX_ADMIN_MODEL=ollama-local linux-admin

Config: config/ollama.env
EOF
}

cmd="${1:-}"
case "$cmd" in
  help|-h|--help)
    usage
    ;;
  creds)
    shift
    exec linux-admin-creds "$@"
    ;;
  doctor)
    exec "$ROOT/scripts/doctor.sh"
    ;;
  doctor-offline)
    exec "$ROOT/scripts/doctor-offline.sh"
    ;;
  bootstrap)
    exec "$ROOT/scripts/bootstrap.sh" "${@:2}"
    ;;
  ensure-local)
    exec "$ROOT/scripts/ensure-local-model.sh"
    ;;
  mcp)
    exec linux-admin-mcp
    ;;
  -p|--print|headless)
    shift
    if [[ $# -eq 0 ]]; then
      echo "usage: linux-admin -p \"prompt\"" >&2
      exit 2
    fi
    prompt="$*"
    echo "linux-admin: model=${MODEL}" >&2
    exec grok -m "$MODEL" --disable-web-search -p "$prompt"
    ;;
  "")
    echo "linux-admin: model=${MODEL}" >&2
    exec grok -m "$MODEL" --disable-web-search
    ;;
  *)
    echo "linux-admin: model=${MODEL}" >&2
    exec grok -m "$MODEL" --disable-web-search "$@"
    ;;
esac
