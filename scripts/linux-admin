#!/usr/bin/env bash
# Primary CLI entry: Grok-style TUI pre-wired for this repo.
#
# Model selection: Grok remembers the last-used model across sessions.
# We do NOT pass -m on every launch (that would override /model and sticky
# last-used). Only force a model when LINUX_ADMIN_MODEL is set, or when
# doing headless one-shots without an explicit model (then auto primary/local).
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

export PATH="${ROOT}/mcp/linux_admin/.venv/bin:${HOME}/.local/bin:${PATH}"
# shellcheck source=/dev/null
source "$ROOT/scripts/lib-env.sh"

# Register model endpoints in user config if missing (does not force default
# every time — see install-user-models.sh --set-default only on bootstrap).
if [[ -x "$ROOT/scripts/install-user-models.sh" ]]; then
  "$ROOT/scripts/install-user-models.sh" >/dev/null 2>&1 || true
fi

usage() {
  cat <<EOF
linux-admin — local Linux admin agent (Grok-style CLI)

Usage:
  linux-admin                 Interactive TUI (Grok last-used / config default)
  linux-admin -p "prompt"     Headless one-shot
  linux-admin creds ...       Credential repository CLI
  linux-admin doctor          Health checks
  linux-admin doctor-offline  Core-path checks
  linux-admin bootstrap       Deps + pick best T4 model on LAN + local fallback
  linux-admin ensure-local    Local break-glass model only
  linux-admin pick-model      Print best LAN model for T4 (no config write)
  linux-admin mcp             MCP stdio server
  linux-admin help

Models (switch anytime in TUI with /model or Ctrl+M):
  ollama-admin   LAN primary  (${OLLAMA_BASE_URL})
  ollama-fast    LAN small
  ollama-local   this host    (${OLLAMA_LOCAL_BASE_URL} / ${OLLAMA_LOCAL_MODEL})

Force a model for one launch:
  LINUX_ADMIN_MODEL=ollama-local linux-admin
  LINUX_ADMIN_MODEL=ollama-admin linux-admin -p "…"

Config: config/ollama.env
EOF
}

# Build optional -m args: only if user forced LINUX_ADMIN_MODEL
grok_model_args() {
  if [[ -n "${LINUX_ADMIN_MODEL:-}" ]]; then
    printf '%s\n' -m "$LINUX_ADMIN_MODEL"
  fi
}

# Headless: if no force, prefer primary when up else local (no sticky session)
headless_model_args() {
  if [[ -n "${LINUX_ADMIN_MODEL:-}" ]]; then
    printf '%s\n' -m "$LINUX_ADMIN_MODEL"
    return
  fi
  local sel
  sel="$(select_grok_model 2>/dev/null || true)"
  if [[ -n "$sel" ]]; then
    printf '%s\n' -m "$sel"
  fi
}

cmd="${1:-}"
case "$cmd" in
  help|-h|--help)
    usage
    ;;
  creds)
    shift
    exec linux-admin-creds "$@"
    ;;
  doctor)
    exec "$ROOT/scripts/doctor.sh"
    ;;
  doctor-offline)
    exec "$ROOT/scripts/doctor-offline.sh"
    ;;
  bootstrap)
    exec "$ROOT/scripts/bootstrap.sh" "${@:2}"
    ;;
  ensure-local)
    exec "$ROOT/scripts/ensure-local-model.sh"
    ;;
  pick-model)
    exec python3 "$ROOT/scripts/pick-admin-model.py" "$OLLAMA_BASE_URL" --rank
    ;;
  mcp)
    exec linux-admin-mcp
    ;;
  -p|--print|headless)
    shift
    if [[ $# -eq 0 ]]; then
      echo "usage: linux-admin -p \"prompt\"" >&2
      exit 2
    fi
    prompt="$*"
    # shellcheck disable=SC2046
    exec grok $(headless_model_args) --disable-web-search -p "$prompt"
    ;;
  "")
    # Interactive: let Grok use last-used / [models].default — do not force -m
    # shellcheck disable=SC2046
    exec grok $(grok_model_args) --disable-web-search
    ;;
  *)
    # shellcheck disable=SC2046
    exec grok $(grok_model_args) --disable-web-search "$@"
    ;;
esac
