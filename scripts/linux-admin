#!/usr/bin/env bash
# Primary CLI entry: Grok-style TUI pre-wired for this repo.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

export PATH="${ROOT}/mcp/linux_admin/.venv/bin:${HOME}/.local/bin:${PATH}"
# shellcheck source=/dev/null
source "$ROOT/scripts/lib-env.sh" 2>/dev/null || true

# Default model id (registered in ~/.grok/config.toml by install-user-models.sh)
MODEL="${LINUX_ADMIN_MODEL:-ollama-admin}"

# Best-effort: ensure user model entries match config/ollama.env
if [[ -x "$ROOT/scripts/install-user-models.sh" ]]; then
  "$ROOT/scripts/install-user-models.sh" >/dev/null 2>&1 || true
fi

usage() {
  cat <<EOF
linux-admin — local Linux admin agent (Grok-style CLI)

Usage:
  linux-admin                 Start interactive Grok TUI in this repo
  linux-admin -p "prompt"     Headless one-shot (also: --print)
  linux-admin creds ...       Credential repository CLI
  linux-admin doctor          Core path health checks
  linux-admin doctor-offline  Core-path checks (LAN Ollama OK; no public cloud LLM)
  linux-admin bootstrap       Install deps + register Grok↔Ollama models
  linux-admin mcp             Run linux-admin-mcp on stdio (debug)
  linux-admin help            This help

Environment / config/ollama.env:
  OLLAMA_BASE_URL     Ollama API root (default: http://192.168.200.120:11434)
  OLLAMA_ADMIN_MODEL  Weight tag on that server (default: qwen2.5-coder:7b)
  LINUX_ADMIN_MODEL   Grok model id (default: ollama-admin)
EOF
}

cmd="${1:-}"
case "$cmd" in
  help|-h|--help)
    usage
    ;;
  creds)
    shift
    exec linux-admin-creds "$@"
    ;;
  doctor)
    exec "$ROOT/scripts/doctor.sh"
    ;;
  doctor-offline)
    exec "$ROOT/scripts/doctor-offline.sh"
    ;;
  bootstrap)
    exec "$ROOT/scripts/bootstrap.sh" "${@:2}"
    ;;
  mcp)
    exec linux-admin-mcp
    ;;
  -p|--print|headless)
    shift
    if [[ $# -eq 0 ]]; then
      echo "usage: linux-admin -p \"prompt\"" >&2
      exit 2
    fi
    prompt="$*"
    exec grok -m "$MODEL" --disable-web-search -p "$prompt"
    ;;
  "")
    exec grok -m "$MODEL" --disable-web-search
    ;;
  *)
    exec grok -m "$MODEL" --disable-web-search "$@"
    ;;
esac
